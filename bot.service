[Unit]
Description=Binance Trading Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/binance-bot
Environment=PATH=/home/ubuntu/binance-bot/venv/bin
ExecStart=/home/ubuntu/binance-bot/venv/bin/python3 main.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
